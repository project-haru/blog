---
import BaseLayout from '../layouts/BaseLayout.astro';
import SpiralCanvas from '../components/SpiralCanvas.astro';
import ArticleOverlay from '../components/ArticleOverlay.astro';
import { getCollection } from 'astro:content';

const rawArticles = await getCollection('articles', ({ data }) => data.status === 'published');
const articles = rawArticles
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .map((a, i) => ({
    id:      i,
    slug:    a.slug,
    title:   a.data.title,
    tag:     a.data.tags[0] ?? 'misc',
    date:    (() => {
      const d = a.data.date;
      return `${d.getFullYear()}.${String(d.getMonth()+1).padStart(2,'0')}.${String(d.getDate()).padStart(2,'0')}`;
    })(),
    excerpt: a.data.excerpt ?? '',
    chars:   a.body?.length ?? 0,
  }));

const articlesJson = JSON.stringify(articles);
---

<BaseLayout title="Project HARU" active="timeline">

  {/* 記事データを window.__HARU_ARTICLES__ に注入（キャンバスより先に実行） */}
  <script is:inline define:vars={{ articlesJson }}>
    window.__HARU_ARTICLES__ = JSON.parse(articlesJson);
  </script>

  {/* 螺旋キャンバス（フルビューポート） */}
  <SpiralCanvas />

  {/* 記事オーバーレイ */}
  <ArticleOverlay />

  {/* タイムライングリッド（螺旋の下） */}
  <section class="hud-tl-wrap" style="margin-top:0">
    <div class="hud-tl-head">
      <span class="hud-tl-label">これまでに起きたこと</span>
      <span class="hud-tl-divider"></span>
      <span class="hud-tl-status">
        <span class="hud-tl-status-dot"></span>
        OBSERVATORY
      </span>
    </div>
    <div class="hud-tl-grid">
      {articles.map((article, i) => (
        <a class="hud-tl-card" href={`/articles/${article.slug}/`}>
          <div class="hud-tl-card-body">
            <div class="hud-tl-meta">
              <div class="hud-tl-meta-l">
                <span class="hud-tl-date">{article.date}</span>
                <span class="hud-tl-tag">haru_writer</span>
              </div>
              <span class="hud-tl-id">REC#{String(articles.length - i).padStart(3, '0')}</span>
            </div>
            <h3 class="hud-tl-title">{article.title}</h3>
            {article.excerpt && <p class="hud-tl-excerpt">{article.excerpt}</p>}
          </div>
        </a>
      ))}
    </div>
  </section>

</BaseLayout>
