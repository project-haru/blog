---
// SpiralCanvas.astro
// 名言＋記事のポイント宇宙。データは index.astro が window.__HARU_POINTS__ に注入する。
---

<!-- 固定全画面レイヤー。HUD(z5)とタイムライン(z4)の下、グリッドオーバーレイ(z1-2)の上 -->
<div id="spiral-root" style="position:fixed;inset:0;overflow:hidden;background:#01020a;z-index:3;">
  <canvas id="spiral-canvas" style="display:block;position:absolute;inset:0;width:100%;height:100%;touch-action:none;"></canvas>
  <!-- 起動シーケンス（ブート演出と同期して消える） -->
  <div id="boot-seq" style="
    position:absolute;inset:0;z-index:2;
    display:flex;align-items:center;justify-content:center;
    pointer-events:none;
    transition:opacity .8s ease;
  ">
    <div id="boot-seq-lines" style="
      font-family:'DM Mono',monospace;font-size:11px;letter-spacing:.14em;
      color:rgba(160,180,255,.8);line-height:2.1;min-width:340px;
    "></div>
  </div>
  <div id="spiral-hint" style="
    position:absolute;bottom:56px;left:50%;transform:translateX(-50%);
    font-family:'DM Mono',monospace;font-size:9px;letter-spacing:.3em;
    color:rgba(160,176,240,.4);pointer-events:none;opacity:0;
    transition:opacity 1.2s ease;
  ">SCROLL // UNIVERSE</div>
</div>

<script is:inline>
(function () {
  /* ── util ─────────────────────────────────────── */
  const Rn = (a, b) => Math.random() * (b - a) + a;
  const R2 = () => Math.random() * 2 - 1;
  const TAU = Math.PI * 2;

  /* ── ポイントデータ（index.astro から注入。quote/article 混在） ─ */
  const points = (window.__HARU_POINTS__ && window.__HARU_POINTS__.length > 0)
    ? window.__HARU_POINTS__.slice()
    : Array.from({ length: 20 }, (_, i) => ({
        kind: 'quote', id: `fallback-${i}`,
        text: 'データ未接続', tags: ['生き方'], confidence: 'legend',
        personData: { name: '—', years: '', title: '', bio: '' },
      }));

  /* ?demo=N でダミー点を補充（プレビュー用。本番データには無影響） */
  const demoCount = parseInt(new URLSearchParams(location.search).get('demo') || '0', 10);
  if (demoCount > points.length) {
    const D_TAGS = ['創造','勇気','愛','努力','知恵','自由','希望','自然','ユーモア','生き方'];
    for (let i = points.length; i < demoCount; i++) {
      points.push({
        kind: 'quote', id: `demo-${i}`,
        text: `デモ名言 #${i + 1} — 実データが増えるとこの位置に本物が並ぶ。`,
        tags: [D_TAGS[i % D_TAGS.length]], confidence: 'legend',
        personData: { name: 'デモ人物', years: '----', title: '', bio: '' },
      });
    }
  }
  const N_PTS = points.length;

  /* ── ジオメトリ定数 ─────────────────────────── */
  const RADIUS = 260, A_STEP = 0.21, ROT_PX = 0.003, FOV = 600, CDIST = 380;
  const SCROLL_H = () => H * 3;
  const CAM_MIN = () => Math.min(H * 0.55, SCROLL_H() / 2);
  const CAM_MAX = () => Math.max(SCROLL_H() - H * 0.55, SCROLL_H() / 2);

  /* ── タグ色（名言系統） ───────────────────────── */
  const TC = {
    '創造':[175,95,255],'勇気':[255,112,112],'愛':[255,125,195],
    '努力':[255,172,72],'知恵':[72,165,255],'自由':[72,218,162],
    '希望':[138,198,255],'自然':[95,215,115],'ユーモア':[255,210,90],'生き方':[198,168,98]
  };
  const ARTICLE_COLOR = [228, 234, 255]; // 記事点 = 白い特別な星
  const TAG_LIST = Object.values(TC);
  function pointColor(p) {
    if (p.kind === 'article') return ARTICLE_COLOR;
    return TC[(p.tags || [])[0]] || [180, 180, 255];
  }
  function mixedColor() {
    const b = TAG_LIST[Math.floor(Math.random() * TAG_LIST.length)];
    const s = Rn(0.3, 0.65);
    return b.map(c => Math.round(c * (1 - s) + 220 * s));
  }

  /* ── canvas セットアップ ────────────────────── */
  const canvas = document.getElementById('spiral-canvas');
  const ctx    = canvas.getContext('2d');
  let W, H;

  /* ── ポイント幾何 ───────────────────────────── */
  let pts = [];
  function rebuildPts() {
    const pitch = SCROLL_H() / (N_PTS - 1 || 1);
    pts = points.map((d, i) => {
      const ors = 0.00015 + Math.pow(Math.random(), 2.2) * 0.0016;
      const isArt = d.kind === 'article';
      return {
        baseAngle: i * A_STEP,
        baseY:     i * pitch,
        nr: Rn(-30, 30), na: Rn(-0.15, 0.15),
        baseSizeMult: isArt ? Rn(1.45, 1.75) : Rn(0.85, 1.15),
        ownRotSpeed: ors,
        ownAngle: ors * Rn(0, 30000),
        tp1: Rn(0, TAU), tf1: Rn(1.0, 3.5),
        tp2: Rn(0, TAU), tf2: Rn(0.5, 1.8),
        twinkleAmp: isArt ? Rn(0.2, 0.4) : Rn(0.35, 0.75),
        _sx: -9999, _sy: -9999,
        d, i,
      };
    });
  }

  /* ── パーティクル ───────────────────────────── */
  const N_WALL = 6000, N_INNER = 3500, N_STAR = 12000;
  let wallPts = [], innerPts = [], starPts = [];
  function rebuildParticles() {
    const sh = SCROLL_H();
    wallPts = Array.from({ length: N_WALL }, () => {
      const angle = Rn(0, TAU), r = RADIUS * Rn(0.75, 1.12);
      return { wx: r * Math.cos(angle), wy: Rn(-H * 0.5, sh + H * 0.5), wz: r * Math.sin(angle),
        size: Rn(0.35, 1.25), alpha: Rn(0.12, 0.45), dy: R2() * 0.018, col: mixedColor(),
        tp: Rn(0, TAU), tf: Rn(0.5, 2.2), ta: Rn(0.2, 0.55) };
    });
    innerPts = Array.from({ length: N_INNER }, () => {
      const wz = Rn(-RADIUS * 0.9, RADIUS * 0.85), ang = Rn(0, TAU), r = Rn(0, RADIUS * 0.6);
      return { wx: r * Math.cos(ang), wy: Rn(-H * 0.5, sh + H * 0.5), wz,
        size: Rn(0.4, 1.8), alpha: Rn(0.1, 0.4), dx: R2() * 0.012, dy: R2() * 0.01, col: mixedColor(),
        tp: Rn(0, TAU), tf: Rn(0.4, 1.8), ta: Rn(0.2, 0.5) };
    });
    starPts = Array.from({ length: N_STAR }, () => ({
      wx: Rn(-W * 0.8, W * 0.8), wy: Rn(-H * 0.5, sh + H * 0.5), wz: Rn(-RADIUS * 1.8, -RADIUS * 0.5),
      size: Rn(0.2, 0.75), alpha: Rn(0.07, 0.26), col: mixedColor(),
      tp: Rn(0, TAU), tf: Rn(0.2, 0.7), ta: Rn(0.1, 0.3)
    }));
  }

  function resize() {
    W = canvas.offsetWidth;
    H = canvas.offsetHeight;
    canvas.width  = W * window.devicePixelRatio;
    canvas.height = H * window.devicePixelRatio;
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
    rebuildPts();
    rebuildParticles();
    if (camY === 0) {
      const midIdx = Math.floor(N_PTS / 2);
      const mid = pts[midIdx] ? pts[midIdx].baseY : SCROLL_H() / 2;
      camY = Math.max(CAM_MIN(), Math.min(CAM_MAX(), mid));
      targetY = camY;
    }
  }

  /* ── 状態 ───────────────────────────────────── */
  let camY = 0, targetY = 0, t = 0, autoRot = 0, lastScrollTime = 0;
  const IDLE_DELAY = 2200, AUTO_SPEED = 0.0004;
  let hovIdx = -1, mx = -9999, my = -9999;
  let ambientIdx = -1, nextAmbientAt = performance.now() + Rn(12000, 25000);

  resize();
  window.addEventListener('resize', resize);

  function onUserInteract() {
    lastScrollTime = performance.now();
    const qs = window.__quotePopupState;
    if (qs && qs.open && qs.auto && typeof window.closeQuotePopup === 'function') {
      window.closeQuotePopup();
    }
    nextAmbientAt = performance.now() + Rn(12000, 25000);
  }

  /* スクロールハンドラ */
  const hint = document.getElementById('spiral-hint');
  let hintShown = true;
  function hideHint() {
    if (!hintShown) return;
    hintShown = false;
    if (hint) hint.style.opacity = '0';
  }
  window.addEventListener('scroll', hideHint, { passive: true });
  function overlayIsOpen() {
    const ov = document.getElementById('article-overlay');
    return !!ov && ov.getAttribute('aria-hidden') === 'false';
  }
  window.addEventListener('wheel', e => {
    if (overlayIsOpen()) return;
    if (window.scrollY > 2) return;
    e.preventDefault();
    targetY = Math.max(CAM_MIN(), Math.min(CAM_MAX(), targetY + e.deltaY * 2.4));
    onUserInteract();
    hideHint();
  }, { passive: false });

  let lty = null;
  canvas.addEventListener('touchstart', e => { lty = e.touches[0].clientY; });
  canvas.addEventListener('touchmove',  e => {
    e.preventDefault(); // ページスクロールとの競合を防ぐ
    if (lty !== null) {
      targetY -= (e.touches[0].clientY - lty) * 3.2;
      targetY = Math.max(CAM_MIN(), Math.min(CAM_MAX(), targetY));
      lty = e.touches[0].clientY;
      onUserInteract();
      hideHint();
    }
  });
  canvas.addEventListener('touchend', () => { lty = null; });
  canvas.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    mx = e.clientX - rect.left;
    my = e.clientY - rect.top;
    canvas.style.cursor = hovIdx >= 0 ? 'pointer' : 'default';
  });

  /* ── クリック: kind で分岐 ───────────────────── */
  function easeIn(x)  { return x * x * x; }
  let clickAnim = null; // 記事ズーム用 { idx, startMs }

  canvas.addEventListener('click', () => {
    if (hovIdx < 0) {
      // 空白クリック = ポップアップの外側クリック。開いていれば閉じる
      const qs = window.__quotePopupState;
      if (qs && qs.open && typeof window.closeQuotePopup === 'function') {
        window.closeQuotePopup();
        nextAmbientAt = performance.now() + Rn(12000, 25000);
      }
      return;
    }
    const p = pts[hovIdx], d = points[hovIdx];
    if (d.kind === 'article') {
      if (clickAnim) return;
      clickAnim = { idx: hovIdx, startMs: performance.now() };
      setTimeout(() => {
        if (typeof window.openArticleOverlay === 'function') window.openArticleOverlay(d);
        clickAnim = null;
      }, 550);
    } else {
      ambientIdx = hovIdx;
      if (typeof window.openQuotePopup === 'function') {
        window.openQuotePopup(d, p._sx, p._sy, { auto: false });
      }
    }
    nextAmbientAt = performance.now() + Rn(12000, 25000);
  });

  /* ── 投影 ───────────────────────────────────── */
  function proj(wx, wy, wz) {
    const dz = CDIST + wz, sc = FOV / Math.max(dz, 8);
    return { sx: W / 2 + wx * sc, sy: H / 2 + (wy - camY) * sc * 1.05, sc, wz };
  }
  function df(wz) { return Math.max(0, Math.min(1, (wz + RADIUS * 1.8) / (RADIUS * 3.6))); }

  function twinkle(p, d, time) {
    const speed = 0.06 + Math.pow(d, 1.8) * 1.6;
    const amp   = p.twinkleAmp * (0.08 + d * 0.92);
    const v     = Math.sin(time * p.tf1 * speed + p.tp1) * Math.sin(time * p.tf2 * speed + p.tp2);
    return 1 - amp * (1 - (v + 1) * 0.5);
  }
  function twinkleP(p, time) {
    const v = Math.sin(time * p.tf + p.tp);
    return 1 - p.ta * (1 - (v + 1) * 0.5);
  }
  function drawGlow(sx, sy, r, g, b, radius, alpha) {
    if (alpha < 0.01 || radius < 0.5) return;
    const gw = ctx.createRadialGradient(sx, sy, 0, sx, sy, radius);
    gw.addColorStop(0,   `rgba(${r},${g},${b},${alpha})`);
    gw.addColorStop(0.4, `rgba(${r},${g},${b},${alpha * 0.4})`);
    gw.addColorStop(1,   `rgba(${r},${g},${b},0)`);
    ctx.beginPath(); ctx.arc(sx, sy, radius, 0, TAU); ctx.fillStyle = gw; ctx.fill();
  }
  function dot(sx, sy, radius, col, a) {
    if (a < 0.01 || radius < 0.1) return;
    ctx.beginPath(); ctx.arc(sx, sy, radius, 0, TAU);
    ctx.fillStyle = `rgba(${col[0]},${col[1]},${col[2]},${Math.min(a, 1)})`; ctx.fill();
  }
  /* 恒星表現: 中心が白熱し、縁がタグ色に溶けて消えるソフトな球。
   * ごく小さい点はグラデーションが見えないので通常の dot にフォールバック */
  function softStar(sx, sy, col, radius, a) {
    a = Math.min(a, 1);
    if (a < 0.01 || radius < 0.3) return;
    if (radius < 1.2) { dot(sx, sy, radius, col, a); return; }
    const [r, g, b] = col;
    const hr = Math.min(255, r + 100), hg = Math.min(255, g + 100), hb = Math.min(255, b + 100);
    const gw = ctx.createRadialGradient(sx, sy, 0, sx, sy, radius);
    gw.addColorStop(0,    `rgba(255,255,255,${a})`);
    gw.addColorStop(0.18, `rgba(${hr},${hg},${hb},${a * 0.9})`);
    gw.addColorStop(0.45, `rgba(${r},${g},${b},${a * 0.5})`);
    gw.addColorStop(1,    `rgba(${r},${g},${b},0)`);
    ctx.beginPath(); ctx.arc(sx, sy, radius, 0, TAU); ctx.fillStyle = gw; ctx.fill();
  }

  /* ── 起動エフェクト ────────────────────────── */
  const BOOT_MS = 3200;
  const bootStart = performance.now();
  function easeOutC(x) { return 1 - Math.pow(1 - x, 3); }
  setTimeout(() => { if (hintShown && hint) hint.style.opacity = '1'; }, BOOT_MS);

  /* ── 起動シーケンス表示（宇宙の収束と同期して消える） ── */
  (function bootSequence() {
    const seq   = document.getElementById('boot-seq');
    const lines = document.getElementById('boot-seq-lines');
    if (!seq || !lines) return;
    const nQuotes = points.filter(p => p.kind !== 'article').length;
    const nMinds  = new Set(points.filter(p => p.kind !== 'article')
      .map(p => (p.personData && p.personData.name) || '')).size;
    const exitMode = new URLSearchParams(location.search).get('exit');

    /* ── 退場演出C: モビルスーツ起動シークエンス ──
     * 高速システムチェック＋レティクル展開＋ALL SYSTEMS GREEN
     * → CRT集束（輝線に潰れて消える）と同時に宇宙が起動する */
    function msBoot() {
      // 中央レティクル（二重円）
      const ret = document.createElement('div');
      ret.style.cssText =
        'position:absolute;left:50%;top:50%;width:360px;height:360px;' +
        'transform:translate(-50%,-50%) scale(.35) rotate(-90deg);opacity:0;' +
        'border:1px solid rgba(124,155,255,.25);border-radius:50%;pointer-events:none;' +
        'transition:transform 1.1s cubic-bezier(.2,.8,.2,1), opacity .9s;';
      const ret2 = document.createElement('div');
      ret2.style.cssText = 'position:absolute;inset:26px;border:1px dashed rgba(124,155,255,.16);border-radius:50%;';
      ret.appendChild(ret2);
      seq.insertBefore(ret, lines.parentNode ? lines : null);
      requestAnimationFrame(() => {
        ret.style.transform = 'translate(-50%,-50%) scale(1) rotate(0deg)';
        ret.style.opacity = '1';
      });

      const MS = [
        ['HARU-01 SYSTEM v0.4', 'head'],
        ['> NEURAL LINK', 'ok'],
        ['> REACTOR OUTPUT 100%', 'ok'],
        ['> FIELD MOTOR DRIVE', 'ok'],
        [`> WORD ARCHIVE ${nQuotes} / ${nMinds}`, 'ok'],
        ['> ORBITAL CALIBRATION', 'ok'],
        ['> COSMO SENSOR ARRAY', 'ok'],
        ['ALL SYSTEMS GREEN', 'green'],
      ];
      const MS_STEP = 170;
      MS.forEach(([text, kind], i) => {
        setTimeout(() => {
          const row = document.createElement('div');
          if (kind === 'head') {
            row.textContent = text;
            row.style.cssText = 'color:rgba(200,214,255,.7);margin-bottom:5px;';
          } else if (kind === 'green') {
            row.textContent = text;
            row.style.cssText =
              'color:#6db87a;letter-spacing:.3em;margin-top:8px;font-weight:500;' +
              'transform:scale(1.35);opacity:0;transition:transform .3s ease-out, opacity .3s;';
            requestAnimationFrame(() => requestAnimationFrame(() => {
              row.style.transform = 'scale(1)'; row.style.opacity = '1';
            }));
          } else {
            row.innerHTML = text +
              ' <span style="opacity:.35">......</span> ' +
              '<span class="ms-ok" style="opacity:0;color:#6db87a;transition:opacity .15s;">OK</span>';
          }
          lines.appendChild(row);
          const ok = row.querySelector('.ms-ok');
          if (ok) setTimeout(() => { ok.style.opacity = '1'; }, 90);
        }, 150 + i * MS_STEP);
      });

      // プログレスバー
      const barWrap = document.createElement('div');
      barWrap.style.cssText = 'margin-top:10px;width:100%;height:2px;background:rgba(100,130,255,.1);';
      const bar = document.createElement('div');
      bar.style.cssText = 'width:0;height:100%;background:rgba(124,155,255,.5);transition:width 1.7s linear;';
      barWrap.appendChild(bar);
      lines.appendChild(barWrap);
      requestAnimationFrame(() => { bar.style.width = '100%'; });

      // 計器の明滅（ノイズ感）。全体をやや透過させて計器らしく
      const FLICK_HI = '0.78', FLICK_LO = '0.5';
      lines.style.opacity = FLICK_HI;
      const flick = setInterval(() => {
        lines.style.opacity = Math.random() < 0.22 ? FLICK_LO : FLICK_HI;
      }, 90);
      setTimeout(() => { clearInterval(flick); lines.style.opacity = FLICK_HI; }, 2250);

      // 退場: 文字と計器は溶け、レティクルの円が見開いて宇宙に開く
      setTimeout(() => {
        lines.style.transition = 'opacity .45s ease, filter .45s ease';
        lines.style.opacity = '0';
        lines.style.filter = 'blur(3px)';
        ret.style.borderColor = 'rgba(170,190,255,.6)';  // 一瞬だけ円が灯る
        ret.style.transition = 'transform 1.1s cubic-bezier(.3,.7,.2,1), opacity 1.1s ease, border-color .3s ease';
        ret.style.transform = 'translate(-50%,-50%) scale(3.8) rotate(40deg)';
        ret.style.opacity = '0';
      }, 2600);
    }

    if (exitMode === 'ms') {
      msBoot();
      setTimeout(() => { seq.remove(); }, 3400);
      return;
    }

    const SEQ = [
      'HARU-01 // WORD-COSMOS',
      '> BOOT SPIRAL FIELD',
      `> LOAD ${nQuotes} WORDS / ${nMinds} MINDS`,
      '> CALIBRATE ORBITS',
      '> WELCOME, TRAVELER',
    ];
    const STEP = 380;            // 行表示の間隔
    const OK_DELAY = 220;        // OK が灯るまで
    SEQ.forEach((text, i) => {
      setTimeout(() => {
        const row = document.createElement('div');
        if (i === 0) {
          row.textContent = text;
          row.style.cssText = 'color:rgba(200,214,255,.9);margin-bottom:6px;';
        } else if (i === SEQ.length - 1) {
          row.textContent = text;
          row.style.cssText = 'color:rgba(124,155,255,.95);margin-top:6px;';
        } else {
          row.innerHTML = text +
            ' <span style="opacity:.35">..........</span> ' +
            '<span class="bs-ok" style="opacity:0;color:#6db87a;transition:opacity .25s;">OK</span>';
        }
        lines.appendChild(row);
        const ok = row.querySelector('.bs-ok');
        if (ok) setTimeout(() => { ok.style.opacity = '1'; }, OK_DELAY);
      }, 200 + i * STEP);
    });
    /* 行を一文字ずつの span に分解する（退場演出の共通下ごしらえ） */
    function splitChars() {
      lines.querySelectorAll(':scope > div').forEach(row => {
        const frag = document.createDocumentFragment();
        row.childNodes.forEach(node => {
          const color = node.nodeType === 1
            ? getComputedStyle(node).color
            : getComputedStyle(row).color;
          for (const ch of node.textContent) {
            const s = document.createElement('span');
            s.textContent = ch;
            s.style.cssText = 'display:inline-block;white-space:pre;color:' + color + ';';
            frag.appendChild(s);
          }
        });
        row.textContent = '';
        row.appendChild(frag);
      });
      return lines.querySelectorAll('span');
    }

    /* 退場演出A: 文字が一字ずつ星屑になって宇宙へ昇っていく */
    function disperse() {
      const spans = splitChars();
      spans.forEach(s => {
        s.style.transition = 'transform 1.2s ease-out, opacity 1.2s ease-out, filter 1.2s ease-out';
      });
      requestAnimationFrame(() => {
        spans.forEach(s => {
          const dx = (Math.random() * 2 - 1) * 100;
          const dy = -30 - Math.random() * 120;
          s.style.transitionDelay = (Math.random() * 0.4) + 's';
          s.style.transform = `translate(${dx}px, ${dy}px) scale(${0.3 + Math.random() * 0.4})`;
          s.style.opacity = '0';
          s.style.filter = 'blur(2px)';
        });
      });
    }

    /* 退場演出B: 全文字が中央の一点へ吸い込まれ、閃光とともに宇宙が生まれる */
    function bigbang() {
      const rect = lines.getBoundingClientRect();
      const cx = rect.left + rect.width / 2, cy = rect.top + rect.height / 2;
      const spans = splitChars();
      spans.forEach(s => {
        s.style.transition =
          'transform .75s cubic-bezier(.55,-.05,.85,.4), opacity .75s ease-in, filter .75s ease-in';
      });
      requestAnimationFrame(() => {
        spans.forEach(s => {
          const r = s.getBoundingClientRect();
          const dx = cx - (r.left + r.width / 2);
          const dy = cy - (r.top + r.height / 2);
          s.style.transitionDelay = (Math.random() * 0.25) + 's';
          s.style.transform = `translate(${dx}px, ${dy}px) scale(.12)`;
          s.style.opacity = '0';
          s.style.filter = 'blur(1px)';
        });
      });
      // 吸い込み完了に合わせて閃光 → 拡散しながら消え、背後で宇宙が姿を現す
      setTimeout(() => {
        const f = document.createElement('div');
        f.style.cssText =
          `position:fixed;left:${cx}px;top:${cy}px;width:10px;height:10px;border-radius:50%;` +
          'transform:translate(-50%,-50%) scale(1);pointer-events:none;z-index:3;' +
          'background:radial-gradient(circle, rgba(255,255,255,.95) 0%, rgba(160,180,255,.5) 40%, rgba(100,130,255,0) 70%);' +
          'transition:transform 1.0s ease-out, opacity 1.0s ease-out;';
        seq.appendChild(f);
        requestAnimationFrame(() => {
          f.style.transform = 'translate(-50%,-50%) scale(48)';
          f.style.opacity = '0';
        });
      }, 800);
    }

    /* デフォルトは星屑散逸。?exit=bang でビッグバン（比較用） */
    setTimeout(exitMode === 'bang' ? bigbang : disperse, 2400);
    setTimeout(() => { seq.remove(); }, 4300);
  })();

  /* ── アンビエント表示 ─────────────────────────
   * 放置中 12〜25 秒間隔で、手前の名言点を増光させてポップアップ */
  function maybeAmbient(vis, boot) {
    const qs = window.__quotePopupState;
    if (qs && !qs.open) {
      if (ambientIdx >= 0 && !clickAnim) ambientIdx = -1;
    }
    if (boot < 1) return;
    if (qs && qs.open) return;
    if (performance.now() < nextAmbientAt) return;
    const cands = vis.filter(v =>
      v.p.d.kind !== 'article' &&
      df(v.wz) > 0.55 &&
      v.p._sx > W * 0.15 && v.p._sx < W * 0.85 &&
      v.p._sy > H * 0.2  && v.p._sy < H * 0.8
    );
    if (cands.length && typeof window.openQuotePopup === 'function') {
      const c = cands[Math.floor(Math.random() * cands.length)];
      ambientIdx = c.i;
      window.openQuotePopup(points[c.i], c.p._sx, c.p._sy, { auto: true });
    }
    nextAmbientAt = performance.now() + Rn(12000, 25000);
  }

  /* ── アニメーションループ ────────────────────── */
  function draw() {
    camY += (targetY - camY) * 0.068;
    t    += 0.008;

    const boot      = easeOutC(Math.min(1, (performance.now() - bootStart) / BOOT_MS));
    const bootScale = 1 + 0.9 * (1 - boot);
    ctx.globalAlpha = boot * boot;

    /* ポップアップ表示中の点は固有公転を減速（読みやすく、星が立ち止まる演出） */
    const popupOpen = window.__quotePopupState && window.__quotePopupState.open;
    for (let pi = 0; pi < pts.length; pi++) {
      const damp = (popupOpen && pi === ambientIdx) ? 0.12 : 1;
      pts[pi].ownAngle += pts[pi].ownRotSpeed * damp;
    }

    const idle       = performance.now() - lastScrollTime;
    const idleFactor = Math.max(0, Math.min(1, (idle - IDLE_DELAY) / 800));
    autoRot += AUTO_SPEED * idleFactor;
    const rotOff = camY * ROT_PX + autoRot;
    const BLEED  = H * 1.5;

    ctx.clearRect(0, 0, W, H);
    const bg = ctx.createRadialGradient(W / 2, H / 2, 0, W / 2, H / 2, Math.max(W, H) * 0.85);
    bg.addColorStop(0, 'rgba(8,10,32,.72)'); bg.addColorStop(1, 'rgba(1,2,10,0)');
    ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);

    /* 遠景星屑 */
    for (const p of starPts) {
      const dy = p.wy - camY; if (dy < -BLEED || dy > BLEED) continue;
      const { sx, sy } = proj(p.wx, p.wy, p.wz);
      if (sx < -20 || sx > W + 20 || sy < -20 || sy > H + 20) continue;
      dot(sx, sy, p.size, p.col, p.alpha * twinkleP(p, t));
    }
    /* 壁面 */
    for (const p of wallPts) {
      const wy = p.wy + p.dy * t * 45, dy = wy - camY; if (dy < -BLEED || dy > BLEED) continue;
      const { sx, sy, wz } = proj(p.wx * bootScale, wy, p.wz * bootScale);
      if (sx < -30 || sx > W + 30 || sy < -30 || sy > H + 30) continue;
      const d = df(wz), tw = twinkleP(p, t);
      dot(sx, sy, p.size * (0.3 + d * 0.9), p.col, p.alpha * (0.2 + d * 0.8) * tw);
    }
    /* 内部浮遊 */
    const iSorted = [...innerPts].sort((a, b) => a.wz - b.wz);
    for (const p of iSorted) {
      const wy = p.wy + p.dy * t * 32, dy = wy - camY; if (dy < -BLEED || dy > BLEED) continue;
      const wx = p.wx + p.dx * t * 28;
      const { sx, sy, sc, wz } = proj(wx * bootScale, wy, p.wz * bootScale);
      if (sx < -40 || sx > W + 40 || sy < -40 || sy > H + 40) continue;
      const d = df(wz), tw = twinkleP(p, t);
      const sz = p.size * (0.15 + d * 1.4) * Math.max(0.18, sc * 0.22);
      const al = p.alpha * (0.1 + d * 0.88) * tw;
      if (d > 0.6) drawGlow(sx, sy, p.col[0], p.col[1], p.col[2], sz * 3, al * 0.18 * d);
      dot(sx, sy, Math.max(0.18, sz), p.col, Math.min(al, 0.78));
    }

    /* ポイント（名言＋記事） */
    const vis = [];
    for (let i = 0; i < N_PTS; i++) {
      const p = pts[i];
      const angle = p.baseAngle + rotOff + p.na + p.ownAngle;
      const r     = (RADIUS + p.nr) * bootScale;
      const wx = r * Math.cos(angle), wy = p.baseY, wz = r * Math.sin(angle);
      if (wy - camY < -BLEED || wy - camY > BLEED) continue;
      vis.push({ wx, wy, wz, i, p });
    }
    vis.sort((a, b) => a.wz - b.wz);

    let cD = 28, nHov = -1;
    vis.forEach(({ wx, wy, wz, i, p }) => {
      const { sx, sy } = proj(wx, wy, wz);
      p._sx = sx; p._sy = sy;
      const [r, g, b] = pointColor(p.d);
      const d  = df(wz);
      const tw = twinkle(p, d, t);
      const coreSize  = (0.1 + Math.pow(d, 2.4) * 9.5) * p.baseSizeMult;
      const coreAlpha = (0.05 + d * 0.90) * tw;
      const isClicked = clickAnim && i === clickAnim.idx;
      const isHov     = i === hovIdx;
      const isAmbient = i === ambientIdx && !isClicked;
      if (isClicked) {
        const elapsed = Math.min((performance.now() - clickAnim.startMs) / 550, 1);
        const zoom = 1 + easeIn(elapsed) * 18;
        const fade = 1 - easeIn(elapsed) * 0.3;
        drawGlow(sx, sy, r, g, b, coreSize * zoom * 6, 0.6 * fade);
        drawGlow(sx, sy, r, g, b, coreSize * zoom * 2, 0.9 * fade);
        softStar(sx, sy, [r, g, b], coreSize * zoom * 1.3, fade);
      } else if (isHov || isAmbient) {
        const pulse = isAmbient ? 0.85 + 0.15 * Math.sin(t * 5) : 1;
        drawGlow(sx, sy, r, g, b, coreSize * 8 * pulse, 0.5);
        drawGlow(sx, sy, r, g, b, coreSize * 3, 0.7);
        softStar(sx, sy, [r, g, b], coreSize * 2.8, 1);
      } else {
        const artBoost = p.d.kind === 'article' ? 1.4 : 1;
        const glowR = coreSize * (2.5 + d * 4.0) * tw * artBoost;
        const glowA = d * d * 0.30 * tw * artBoost;
        if (glowA > 0.015) drawGlow(sx, sy, r, g, b, glowR, glowA);
        softStar(sx, sy, [r, g, b], Math.max(0.3, coreSize * 1.7), coreAlpha);
      }
      if (wz > -60) {
        const dd = Math.hypot(sx - mx, sy - my);
        if (dd < cD) { cD = dd; nHov = i; }
      }
    });
    hovIdx = nHov;

    /* ポップアップを対象の点に追従させる（点はゆっくり公転している） */
    const pqs = window.__quotePopupState;
    if (pqs && pqs.open && ambientIdx >= 0 && pts[ambientIdx] &&
        typeof window.moveQuotePopup === 'function') {
      window.moveQuotePopup(pts[ambientIdx]._sx, pts[ambientIdx]._sy);
    }

    maybeAmbient(vis, boot);

    /* ビネット */
    const vg = ctx.createRadialGradient(
      W / 2, H / 2, Math.min(W, H) * 0.38,
      W / 2, H / 2, Math.max(W, H) * 0.78
    );
    vg.addColorStop(0, 'rgba(0,1,6,0)');
    vg.addColorStop(1, 'rgba(0,1,6,0.6)');
    ctx.fillStyle = vg; ctx.fillRect(0, 0, W, H);

    requestAnimationFrame(draw);
  }
  draw();
})();
</script>
