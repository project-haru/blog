---
// ArticleOverlay.astro
// JS から window.openArticleOverlay(article) / window.closeArticleOverlay() で制御する
---

<!-- 螺旋の輝度を下げるフィルター層 -->
<div id="spiral-dimmer" style="
  position:fixed;inset:0;z-index:20;
  background:#01020a;opacity:0;pointer-events:none;
  transition:opacity 0.55s ease;
"></div>

<!-- 記事オーバーレイ本体 -->
<div id="article-overlay" style="
  position:fixed;inset:0;z-index:30;
  display:flex;flex-direction:column;align-items:center;justify-content:flex-start;
  overflow-y:auto;opacity:0;pointer-events:none;
  transition:opacity 0.45s ease;
" aria-hidden="true">
  <div id="article-inner" style="
    width:min(660px, 90vw);padding:72px 0 80px;
    transform:translateY(16px);
    transition:transform 0.55s cubic-bezier(.16,1,.3,1), opacity 0.55s ease;
    opacity:0;
  ">
    <div id="ov-tag"  style="font-size:9px;letter-spacing:.22em;opacity:.32;margin-bottom:16px;font-family:'DM Mono',monospace;color:#c0ccff;"></div>
    <div id="ov-title" style="font-size:26px;letter-spacing:.06em;color:#d8e0ff;line-height:1.38;margin-bottom:20px;font-family:'DM Mono',monospace;"></div>
    <div id="ov-meta"  style="
      display:flex;gap:20px;font-size:9px;letter-spacing:.14em;opacity:.28;margin-bottom:44px;
      padding-bottom:24px;border-bottom:1px solid rgba(100,130,255,.1);
      font-family:'DM Mono',monospace;color:#c0ccff;
    "></div>
    <div id="ov-body"  style="font-size:14px;line-height:1.9;opacity:.68;letter-spacing:.04em;color:#c0ccff;"></div>
    <a id="ov-link" href="#" style="
      display:inline-block;margin-top:40px;
      padding:10px 28px;border:1px solid rgba(100,130,255,.25);border-radius:20px;
      background:rgba(100,130,255,.06);color:#b8c8ff;
      font-family:'DM Mono',monospace;font-size:10px;letter-spacing:.18em;
      text-decoration:none;transition:background .15s;
    ">記事を読む →</a>
  </div>
</div>

<!-- 閉じるボタン -->
<button id="overlay-close" onclick="window.closeArticleOverlay()" style="
  position:fixed;top:24px;right:28px;z-index:40;
  width:36px;height:36px;border:1px solid rgba(255,255,255,.1);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;font-size:13px;color:#c0ccff;
  background:rgba(5,7,22,.7);backdrop-filter:blur(8px);
  opacity:0;pointer-events:none;
  transition:opacity .4s ease;
" aria-label="閉じる">✕</button>

<script is:inline>
(function () {
  const dimmer  = document.getElementById('spiral-dimmer');
  const overlay = document.getElementById('article-overlay');
  const inner   = document.getElementById('article-inner');
  const closeBtn= document.getElementById('overlay-close');

  window.openArticleOverlay = function (article) {
    // データ注入
    document.getElementById('ov-tag').textContent   = `#${article.tag} · REC#${article.recNo ?? '—'}`;
    document.getElementById('ov-title').textContent = article.title;
    document.getElementById('ov-meta').innerHTML    =
      `<span>${article.date}</span><span>${article.chars ?? '—'} chars</span>`;
    document.getElementById('ov-body').textContent  = article.excerpt ?? '';
    document.getElementById('ov-link').href         = `/articles/${article.slug}/`;

    // フェーズ1: dimmer フェードイン
    dimmer.style.opacity = '0';
    dimmer.style.pointerEvents = 'all';
    requestAnimationFrame(() => { dimmer.style.opacity = '0.82'; });

    // フェーズ2 (200ms後): オーバーレイ出現
    setTimeout(() => {
      overlay.style.opacity       = '1';
      overlay.style.pointerEvents = 'all';
      overlay.setAttribute('aria-hidden', 'false');
      inner.style.opacity   = '1';
      inner.style.transform = 'translateY(0)';
      closeBtn.style.opacity       = '0.5';
      closeBtn.style.pointerEvents = 'all';
    }, 200);
  };

  window.closeArticleOverlay = function () {
    overlay.style.opacity       = '0';
    overlay.style.pointerEvents = 'none';
    overlay.setAttribute('aria-hidden', 'true');
    inner.style.opacity   = '0';
    inner.style.transform = 'translateY(16px)';
    dimmer.style.opacity  = '0';
    closeBtn.style.opacity       = '0';
    closeBtn.style.pointerEvents = 'none';
    setTimeout(() => { dimmer.style.pointerEvents = 'none'; }, 550);
  };

  // backdrop クリックで閉じる
  overlay.addEventListener('click', e => {
    if (e.target === overlay) window.closeArticleOverlay();
  });
})();
</script>
